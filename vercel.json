{
  "version": 2,
  "name": "clamflow-cloud",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "DATABASE_URL": "@database-url",
    "SUPABASE_URL": "@supabase-url", 
    "SUPABASE_ANON_KEY": "@supabase-anon-key",
    "SUPABASE_SERVICE_ROLE_KEY": "@supabase-service-role-key",
    "API_BASE_URL": "https://clamflow-cloud.vercel.app"
  },
  "functions": {
    "api/index.py": {
      "runtime": "python3.9"
    }
  }
}
